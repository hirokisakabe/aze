{
  "name": "aze-cli",
  "version": "0.1.0",
  "description": "ローカルの Markdown ディレクトリをブラウザの aze エディタで編集する CLI (aze serve)",
  "type": "module",
  "bin": {
    "aze": "dist-cli/aze.js"
  },
  "files": [
    "dist-cli",
    "dist-fs"
  ],
  "keywords": [
    "cli",
    "markdown",
    "editor",
    "notes"
  ],
  "homepage": "https://github.com/hirokisakabe/aze#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokisakabe/aze.git"
  },
  "bugs": {
    "url": "https://github.com/hirokisakabe/aze/issues"
  },
  "author": "hirokisakabe",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepublishOnly": "npm run build:local",
    "dev": "vite",
    "build": "vite build",
    "build:serve": "VITE_STORAGE_DRIVER=fs vite build --outDir dist-fs",
    "build:cli": "esbuild bin/aze.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist-cli/aze.js --banner:js='#!/usr/bin/env node' && chmod +x dist-cli/aze.js",
    "build:local": "npm run build:serve && npm run build:cli",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src e2e bin",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"e2e/**/*.ts\" \"bin/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"e2e/**/*.ts\" \"bin/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "knip": "knip"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "dexie": "^4.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "knip": "^6.14.2",
    "lucide-react": "^1.17.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "sirv": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  }
}
